# ===== Runtime =====
APP_ENV=dev
SERVICE_NAME=api
HTTP_PORT=8080
DEBUG_ROUTES=0
HTTP_ADDR=:8080
SHUTDOWN_TIMEOUT=10s

# ===== DB (dev) =====
DB_DSN=postgres://postgres:postgres@localhost:5432/app?sslmode=disable

# ===== CORS/Origins =====
AUTH_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080

# ===== Google OIDC (dev placeholders) =====
AUTH_GOOGLE_ISSUER=https://accounts.google.com
AUTH_GOOGLE_CLIENT_ID=dev
AUTH_GOOGLE_CLIENT_SECRET=dev
AUTH_GOOGLE_REDIRECT_URL=http://localhost:8080/v1/auth/google/callback

# ===== JWT (dev) =====
AUTH_JWT_ISSUER=your-api
AUTH_JWT_AUDIENCE=your-api
AUTH_JWT_KID=dev
AUTH_JWT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===== Refresh/session =====
AUTH_STATE_TTL_MIN=5
AUTH_ACCESS_TTL_MIN=15
AUTH_REFRESH_TTL_HOURS=720
AUTH_REFRESH_PEPPER=dev-refresh-pepper-1234
AUTH_REFRESH_COOKIE=refresh
AUTH_CSRF_COOKIE=csrf

# ===== Cookie policy (dev) =====
COOKIE_DOMAIN=
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
